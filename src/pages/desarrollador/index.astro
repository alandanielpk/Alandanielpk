---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  developerLogos,
  developerProjects,
  developerSkills,
  developerSocialLinks,
} from "../../data/site.js";
---

<BaseLayout
  title="Desarrollador"
  description="Perfil tecnico de Alan Daniel: experiencia, herramientas y proyectos."
>
  <section class="section-shell">
    <div class="grid gap-8 lg:grid-cols-[0.95fr,1.05fr] lg:items-start">
      <div class="space-y-6">
        <span class="eyebrow">Desarrollador</span>
        <h1 class="text-4xl font-bold text-white sm:text-5xl">Desarrollo web con enfoque visual</h1>
        <p class="text-lg leading-8 text-slate-300">
          Aqui esta resumida mi base tecnica: front-end, back-end, herramientas de trabajo y
          proyectos que mezclan producto y diseno.
        </p>

        <div class="flex flex-wrap gap-3">
          {
            developerSocialLinks.map((link) => (
              <a href={link.href} target="_blank" rel="noreferrer" class="social-link">
                {link.label}
              </a>
            ))
          }
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {
          developerSkills.map((skillGroup) => (
            <div class="info-card">
              <p class="text-sm uppercase tracking-[0.24em] text-amber-200">{skillGroup.title}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {skillGroup.items.map((item) => <span class="pill">{item}</span>)}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-shell pt-0">
    <div class="flex flex-col gap-3">
      <span class="eyebrow">Conocimientos</span>
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Tecnologias que uso y he usado</h2>
    </div>
    <div class="mt-8 grid gap-4 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6">
      {
        developerLogos.map((logo) => (
          <a
            href={logo.href}
            target="_blank"
            rel="noreferrer"
            class="panel flex min-h-28 items-center justify-center p-5 hover:-translate-y-1"
          >
            <img src={logo.image} alt={logo.alt} class="max-h-16 w-auto object-contain" />
          </a>
        ))
      }
    </div>
  </section>

  <section class="section-shell pt-0">
    <div class="flex flex-col gap-3">
      <span class="eyebrow">Proyectos</span>
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Trabajos y rutas reservadas</h2>
    </div>
    <div class="mt-8 grid gap-6 md:grid-cols-2">
      {
        developerProjects.map((project) => (
          <a
            href={project.href}
            target={project.href.startsWith("http") ? "_blank" : undefined}
            rel={project.href.startsWith("http") ? "noreferrer" : undefined}
            class="panel overflow-hidden p-0 hover:-translate-y-1"
          >
            <div class="grid h-full gap-0 sm:grid-cols-[0.7fr,1.3fr]">
              <div class="flex min-h-48 items-center justify-center bg-gradient-to-br from-white/5 to-transparent p-8">
                <img src={project.image} alt={project.title} class="max-h-20 w-auto object-contain" />
              </div>
              <div class="p-8">
                <p class="text-sm uppercase tracking-[0.24em] text-amber-200">{project.type}</p>
                <h3 class="mt-3 text-2xl font-bold text-white">{project.title}</h3>
                <p class="mt-4 text-sm leading-7 text-slate-400">{project.description}</p>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
