---
import BaseLayout from "../layouts/BaseLayout.astro";
import { featureAreas } from "../data/site.js";
---

<BaseLayout
  title="Inicio"
  description="Portafolio personal de Alan Daniel Londono con enfoque en desarrollo web y multimedia."
>
  <section class="section-shell">
    <div class="grid gap-8 lg:grid-cols-[1.05fr,0.95fr] lg:items-center">
      <div class="space-y-6">
        <span class="eyebrow">Portafolio personal</span>
        <h1 class="max-w-3xl text-4xl font-bold leading-tight text-white sm:text-5xl lg:text-6xl">
          Desarrollo productos web con una capa visual clara, tecnica y lista para produccion.
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-slate-300">
          Soy Alan Daniel Londono, desarrollador de software y creador multimedia en Medellin.
          Combino codigo e imagen para presentar proyectos con mejor narrativa y mejor acabado.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/desarrollador" class="btn-primary">Ver perfil tecnico</a>
          <a href="/multimedia" class="btn-secondary">Explorar multimedia</a>
        </div>
        <div class="grid gap-4 sm:grid-cols-3">
          <div class="info-card">
            <p class="text-3xl font-bold text-white">2+</p>
            <p class="mt-2 text-sm text-slate-400">Anos construyendo experiencias web.</p>
          </div>
          <div class="info-card">
            <p class="text-3xl font-bold text-white">3+</p>
            <p class="mt-2 text-sm text-slate-400">Anos trabajando contenido multimedia.</p>
          </div>
          <div class="info-card">
            <p class="text-3xl font-bold text-white">1</p>
            <p class="mt-2 text-sm text-slate-400">Perfil que une desarrollo y contenido visual.</p>
          </div>
        </div>
      </div>

      <div class="panel overflow-hidden p-6 sm:p-8">
        <div class="grid gap-4 md:grid-cols-[1.15fr,0.85fr]">
          <div class="relative overflow-hidden rounded-[1.75rem] border border-white/10 bg-gradient-to-br from-amber-300/20 via-white/5 to-emerald-400/10 p-4">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(251,191,36,0.18),transparent_45%)]"></div>
            <img
              src="/ALANTRANSPARENTE.png"
              alt="Retrato de Alan Daniel"
              class="relative mx-auto h-full max-h-[24rem] object-contain"
            />
          </div>
          <div class="flex flex-col gap-4">
            <div class="rounded-[1.75rem] border border-white/10 bg-white/5 p-5">
              <p class="text-sm uppercase tracking-[0.24em] text-amber-200">Rol principal</p>
              <h2 class="mt-3 text-2xl font-bold text-white">Software + multimedia</h2>
              <p class="mt-3 text-sm leading-7 text-slate-400">
                Desarrollo interfaces y tambien produzco los recursos visuales que las acompanan.
              </p>
            </div>
            <div class="rounded-[1.75rem] border border-white/10 bg-slate-900/70 p-5">
              <p class="text-sm uppercase tracking-[0.24em] text-emerald-300">Enfoque</p>
              <h2 class="mt-3 text-2xl font-bold text-white">Tecnica con identidad visual</h2>
              <p class="mt-3 text-sm leading-7 text-slate-400">
                Busco que cada proyecto tenga claridad tecnica, buena presentacion y una identidad propia.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell pt-0">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div class="space-y-3">
        <span class="eyebrow">Areas principales</span>
        <h2 class="text-3xl font-bold text-white sm:text-4xl">Trabajo entre producto y contenido</h2>
      </div>
      <p class="max-w-2xl text-sm leading-7 text-slate-400">
        Estas secciones resumen mi trabajo entre desarrollo, diseno y produccion visual.
      </p>
    </div>

    <div class="mt-8 grid gap-6 lg:grid-cols-2">
      {
        featureAreas.map((item) => (
          <a href={item.href} class="panel group overflow-hidden p-0 hover:-translate-y-1">
            <div class="grid gap-0 md:grid-cols-[0.8fr,1.2fr]">
              <div class="flex items-center justify-center bg-gradient-to-br from-white/5 to-white/0 p-8">
                <img src={item.image} alt={item.title} class="h-28 w-28 object-contain sm:h-32 sm:w-32" />
              </div>
              <div class="p-8">
                <p class="text-sm uppercase tracking-[0.24em] text-amber-200">Especialidad</p>
                <h3 class="mt-3 text-2xl font-bold text-white">{item.title}</h3>
                <p class="mt-4 text-sm leading-7 text-slate-300">{item.description}</p>
                <p class="mt-6 text-sm font-medium text-emerald-300">{item.note}</p>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="section-shell pt-0">
    <div class="grid gap-6 lg:grid-cols-3">
      <div class="info-card">
        <p class="text-sm uppercase tracking-[0.24em] text-amber-200">Producto</p>
        <h3 class="mt-3 text-2xl font-bold text-white">Soluciones claras</h3>
        <p class="mt-4 text-sm leading-7 text-slate-400">
          Me interesa crear experiencias web ordenadas, utiles y faciles de recorrer.
        </p>
      </div>
      <div class="info-card">
        <p class="text-sm uppercase tracking-[0.24em] text-amber-200">Visual</p>
        <h3 class="mt-3 text-2xl font-bold text-white">Imagen con criterio</h3>
        <p class="mt-4 text-sm leading-7 text-slate-400">
          La parte grafica acompana el mensaje del proyecto y ayuda a darle mas personalidad.
        </p>
      </div>
      <div class="info-card">
        <p class="text-sm uppercase tracking-[0.24em] text-amber-200">Proceso</p>
        <h3 class="mt-3 text-2xl font-bold text-white">Trabajo integral</h3>
        <p class="mt-4 text-sm leading-7 text-slate-400">
          Puedo aportar desde la idea visual hasta la construccion del producto final.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
