---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  multimediaGallery,
  multimediaSocialLinks,
  multimediaTools,
} from "../data/site.js";
---

<BaseLayout
  title="Multimedia"
  description="Portafolio multimedia de Alan Daniel con fotografía, video y diseño gráfico."
>
  <section class="section-shell">
    <div class="grid gap-8 lg:grid-cols-[0.9fr,1.1fr] lg:items-start">
      <div class="space-y-6">
        <span class="eyebrow">Multimedia</span>
        <h1 class="text-4xl font-bold text-white sm:text-5xl">Creador multimedia</h1>
        <p class="text-lg leading-8 text-slate-300">
          Esta sección reúne fotografía, videografía y diseño gráfico. El objetivo es mostrar cómo
          la parte visual complementa mi trabajo técnico.
        </p>

        <div class="flex flex-wrap gap-3">
          {
            multimediaSocialLinks.map((link) => (
              <a href={link.href} target="_blank" rel="noreferrer" class="social-link">
                {link.label}
              </a>
            ))
          }
        </div>

        <div class="info-card">
          <p class="text-sm uppercase tracking-[0.24em] text-amber-200">Herramientas</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {multimediaTools.map((tool) => <span class="pill">{tool}</span>)}
          </div>
        </div>
      </div>

      <div class="panel p-6">
        <div class="aspect-video overflow-hidden rounded-[1.75rem] border border-white/10">
          <iframe
            class="h-full w-full"
            src="https://www.youtube.com/embed/m3679oCE6vU?si=-0WggqTpdhePP-S4"
            title="Video destacado de Alan Daniel"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell pt-0">
    <div class="flex flex-col gap-3">
      <span class="eyebrow">Galería</span>
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Fotografía, video y composición</h2>
    </div>
    <div class="mt-8 columns-1 gap-4 md:columns-2 xl:columns-3">
      {
        multimediaGallery.map((image, index) => (
          <div class="mb-4 break-inside-avoid overflow-hidden rounded-[1.75rem] border border-white/10 bg-white/5">
            <img
              src={image}
              alt={`Trabajo multimedia ${index + 1}`}
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
