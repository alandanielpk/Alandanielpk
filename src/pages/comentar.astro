---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contacto"
  description="Formulario de contacto para enviar comentarios o solicitudes a Alan Daniel."
>
  <section class="section-shell">
    <div class="grid gap-8 lg:grid-cols-[0.95fr,1.05fr] lg:items-start">
      <div class="space-y-6">
        <span class="eyebrow">Contacto</span>
        <h1 class="text-4xl font-bold text-white sm:text-5xl">Deja un comentario</h1>
        <p class="text-lg leading-8 text-slate-300">
          Si tienes dudas, una propuesta o necesitas ayuda, este formulario envia el mensaje
          directamente por correo.
        </p>
        <div class="info-card">
          <p class="text-sm uppercase tracking-[0.24em] text-amber-200">Respuesta</p>
          <p class="mt-3 text-sm leading-7 text-slate-400">
            El mensaje llega directo a mi correo para poder responderte por este mismo medio.
          </p>
        </div>
      </div>

      <div class="panel p-6 sm:p-8">
        <form
          id="contact-form"
          action="https://formsubmit.co/alandaniellon01@gmail.com"
          method="POST"
          class="grid gap-4"
        >
          <input type="hidden" name="_subject" value="Nuevo mensaje desde el portafolio" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_template" value="table" />

          <label class="grid gap-2 text-sm text-slate-300">
            Nombre
            <input class="field" type="text" name="name" placeholder="Tu nombre" required />
          </label>

          <label class="grid gap-2 text-sm text-slate-300">
            Correo
            <input class="field" type="email" name="email" placeholder="tu@correo.com" required />
          </label>

          <label class="grid gap-2 text-sm text-slate-300">
            Comentario
            <textarea
              class="field min-h-40 resize-y"
              name="comment"
              placeholder="Escribe tu mensaje"
              required
            ></textarea>
          </label>

          <div
            id="form-status"
            class="hidden rounded-2xl border px-4 py-3 text-sm"
            aria-live="polite"
          ></div>

          <button
            id="form-submit"
            type="submit"
            class="btn-primary w-full sm:w-auto disabled:translate-y-0 disabled:cursor-not-allowed disabled:opacity-70"
          >
            Enviar mensaje
          </button>

          <p class="text-xs leading-6 text-slate-500">
            Si algo falla, puedes intentar de nuevo en unos segundos.
          </p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const form = document.getElementById("contact-form");
  const statusBox = document.getElementById("form-status");
  const submitButton = document.getElementById("form-submit");

  const showStatus = (type, message) => {
    if (!statusBox) return;

    statusBox.classList.remove(
      "hidden",
      "border-emerald-300/20",
      "bg-emerald-300/10",
      "text-emerald-100",
      "border-rose-300/20",
      "bg-rose-300/10",
      "text-rose-100",
      "border-amber-300/20",
      "bg-amber-300/10",
      "text-amber-100",
    );

    if (type === "success") {
      statusBox.classList.add("border-emerald-300/20", "bg-emerald-300/10", "text-emerald-100");
    } else if (type === "error") {
      statusBox.classList.add("border-rose-300/20", "bg-rose-300/10", "text-rose-100");
    } else {
      statusBox.classList.add("border-amber-300/20", "bg-amber-300/10", "text-amber-100");
    }

    statusBox.textContent = message;
  };

  if (form instanceof HTMLFormElement && statusBox && submitButton instanceof HTMLButtonElement) {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      submitButton.disabled = true;
      showStatus("loading", "Enviando mensaje...");

      try {
        const formData = new FormData(form);
        const response = await fetch("https://formsubmit.co/ajax/alandaniellon01@gmail.com", {
          method: "POST",
          headers: {
            Accept: "application/json",
          },
          body: formData,
        });

        if (!response.ok) {
          throw new Error("request_failed");
        }

        const result = await response.json();

        if (result.success !== "true" && result.success !== true) {
          throw new Error("request_failed");
        }

        form.reset();
        showStatus("success", "Mensaje enviado. Puedes seguir en esta pagina sin salir del sitio.");
      } catch (error) {
        showStatus(
          "error",
          "No pude enviar el mensaje ahora. Intenta de nuevo en unos segundos.",
        );
      } finally {
        submitButton.disabled = false;
      }
    });
  }
</script>
