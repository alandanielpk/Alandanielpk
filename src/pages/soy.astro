---
import BaseLayout from "../layouts/BaseLayout.astro";
import { portraitGallery, studyItems, workItems } from "../data/site.js";
---

<BaseLayout
  title="Perfil"
  description="Perfil profesional de Alan Daniel Londoño Chavarría, formación y experiencia."
>
  <section class="section-shell">
    <div class="grid gap-8 lg:grid-cols-[1.05fr,0.95fr] lg:items-start">
      <div class="space-y-6">
        <span class="eyebrow">Perfil</span>
        <h1 class="text-4xl font-bold text-white sm:text-5xl">
          Soy Alan Daniel Londoño Chavarría
        </h1>
        <p class="text-lg leading-8 text-slate-300">
          Soy técnico en desarrollo de software y he participado en varios proyectos durante los
          últimos años. Mi enfoque es mezclar conocimientos técnicos con mirada multimedia para
          diseñar experiencias web con una identidad más sólida.
        </p>
        <p class="text-base leading-8 text-slate-400">
          Me interesa construir productos donde el diseño, la implementación y la presentación final
          se sientan conectados. Esa mezcla es la que quiero seguir profundizando.
        </p>
        <div class="flex flex-wrap gap-3">
          <span class="pill">Desarrollo web</span>
          <span class="pill">Contenido visual</span>
          <span class="pill">Diseño de interfaces</span>
          <span class="pill">Aprendizaje continuo</span>
        </div>
      </div>

      <div class="panel p-4 sm:p-5">
        <div class="grid grid-cols-2 gap-4">
          {
            portraitGallery.map((image, index) => (
              <div
                class:list={[
                  "overflow-hidden rounded-[1.5rem] border border-white/10 bg-white/5",
                  (index === 0 || index === 5) && "col-span-2",
                ]}
              >
                <img
                  src={image}
                  alt={`Foto de Alan Daniel ${index + 1}`}
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell pt-0">
    <div class="flex flex-col gap-3">
      <span class="eyebrow">Formación</span>
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Estudios y aprendizaje</h2>
    </div>
    <div class="mt-8 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {
        studyItems.map((item) => (
          <a
            href={item.href}
            target="_blank"
            rel="noreferrer"
            class="info-card hover:-translate-y-1"
          >
            <div class="flex h-16 items-center">
              <img src={item.image} alt={item.title} class="max-h-12 w-auto object-contain" />
            </div>
            <h3 class="mt-5 text-xl font-bold text-white">{item.title}</h3>
            <p class="mt-2 text-sm leading-7 text-slate-400">{item.subtitle}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="section-shell pt-0">
    <div class="flex flex-col gap-3">
      <span class="eyebrow">Experiencia</span>
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Trabajos y colaboraciones</h2>
    </div>
    <div class="mt-8 grid gap-6 md:grid-cols-2">
      {
        workItems.map((item) => (
          <a
            href={item.href}
            target="_blank"
            rel="noreferrer"
            class="panel flex flex-col gap-6 p-8 hover:-translate-y-1 sm:flex-row sm:items-center"
          >
            <div class="flex h-20 w-28 items-center justify-center rounded-[1.5rem] border border-white/10 bg-white/5 p-4">
              <img src={item.image} alt={item.title} class="max-h-12 w-auto object-contain" />
            </div>
            <div>
              <p class="text-sm uppercase tracking-[0.24em] text-amber-200">Trayectoria</p>
              <h3 class="mt-3 text-2xl font-bold text-white">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-400">{item.subtitle}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
