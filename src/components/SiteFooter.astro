---
import { footerSocialLinks, siteMeta } from "../data/site.js";
---

<footer class="border-t border-white/10">
  <div class="section-shell flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
    <div class="space-y-2">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-amber-200">
        {siteMeta.title}
      </p>
      <p class="max-w-xl text-sm text-slate-400">
        Portafolio personal de desarrollo web y multimedia.
      </p>
    </div>

    <div class="flex flex-col items-start gap-4 lg:items-end">
      <div class="flex flex-wrap items-center gap-3">
        {
          footerSocialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noreferrer"
              aria-label={link.label}
              title={link.label}
              class="footer-icon-link"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="currentColor">
                {
                  link.platform === "tiktok" && (
                    <path d="M14.5 4.5c.6 1.6 1.8 2.9 3.5 3.5v2.7c-1.4-.1-2.7-.5-3.8-1.3v5.1a5.7 5.7 0 1 1-5.7-5.6c.4 0 .8 0 1.2.1v2.8a3 3 0 1 0 1.8 2.7V2.5h3v2Z"></path>
                  )
                }
                {
                  link.platform === "instagram" && (
                    <>
                      <rect
                        x="4.5"
                        y="4.5"
                        width="15"
                        height="15"
                        rx="4.5"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                      ></rect>
                      <circle
                        cx="12"
                        cy="12"
                        r="3.6"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                      ></circle>
                      <circle cx="17.1" cy="6.9" r="1.1"></circle>
                    </>
                  )
                }
                {
                  link.platform === "facebook" && (
                    <path d="M13.4 20v-6.2h2.2l.5-2.7h-2.7V9.5c0-.9.3-1.5 1.6-1.5H16V5.6c-.6-.1-1.3-.2-2-.2-2.4 0-3.9 1.4-3.9 4.1v1.6H8v2.7h2.1V20h3.3Z"></path>
                  )
                }
              </svg>
              <span class="sr-only">{link.label}</span>
            </a>
          ))
        }
      </div>

      <div class="flex flex-col items-start gap-2 text-sm text-slate-400 sm:flex-row sm:items-center">
        <span>{siteMeta.location}</span>
        <span>&copy; 2026 {siteMeta.title}</span>
      </div>
    </div>
  </div>
</footer>
